{
  "name": "papipo-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev --workspace @papipo/api",
    "dev:admin": "npm run dev --workspace @papipo/admin",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:generate": "npm run prisma:generate --workspace @papipo/api",
    "db:migrate": "npm run prisma:migrate --workspace @papipo/api",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down -v"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
