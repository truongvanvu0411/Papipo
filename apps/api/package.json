{
  "name": "@papipo/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm --prefix ../.. run build --workspace @papipo/contracts && prisma generate && tsc -p tsconfig.build.json",
    "start": "node dist/src/main.js",
    "start:dev": "tsx watch src/main.ts",
    "lint": "npm --prefix ../.. run build --workspace @papipo/contracts && prisma generate && tsc --noEmit -p tsconfig.json",
    "test": "npm --prefix ../.. run build --workspace @papipo/contracts && prisma generate && node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --runInBand --config jest.config.cjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "seed:fixtures": "tsx scripts/seed-fixtures.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/swagger": "^11.2.0",
    "@papipo/contracts": "file:../../packages/contracts",
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.2.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.14.0",
    "@types/supertest": "^6.0.3",
    "@nestjs/testing": "^11.1.6",
    "jest": "^29.7.0",
    "prisma": "^6.6.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.2.5",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
